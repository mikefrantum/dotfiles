{
  "layer": "top", // Waybar at top layer
  "position": "top", // Waybar position (top|bottom|left|right)
  "height": 46,
  "margin": "0 0 0 0",
  "output": "DP-2",
  //"width": 1350, // Waybar width
  // Choose the order of the modules idle_inhibitor
  "modules-left": [
    "custom/launcher",
    "sway/workspaces",
    "custom/swap",
    "tray",
    "sway/window",
    "sway/mode",
    "mpd#2",
    "mpd#3",
    "mpd#4",
    "mpd"
  ],
  "modules-center": ["clock"],
  "modules-right": [
    "backlight",
    "pulseaudio",
    "temperature",
    // "cpu",
    // "memory",
    // "disk",
    "group/hardware",
    "battery",
    "network",
    "idle_inhibitor",
    "custom/power"
  ],


    // Load Modules
    "include": ["~/.config/waybar/modules.json"],

  // Modules configuration

    "custom/cava-internal": {
    "exec": "~/.config/waybar/scripts/Cava.sh",
    "return-type": "text",
    "format": "{}",
    "tooltip": false,
    "restart-interval": 1,
    "exec-if": "which cava"
  }

}
