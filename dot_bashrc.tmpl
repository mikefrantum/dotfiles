# ~/.bashrc: executed by bash(1) for non-login shells.

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# ==============================================================================
# History
# ==============================================================================
HISTCONTROL=ignoreboth
HISTSIZE=1000
HISTFILESIZE=2000
shopt -s histappend

# ==============================================================================
# Shell Options
# ==============================================================================
shopt -s checkwinsize
set -o vi
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi

# ==============================================================================
# Prompt
# ==============================================================================
case "$TERM" in
    xterm-color|*-256color) color_prompt=yes;;
esac
if [ -n "$force_color_prompt" ]; then
    if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
        color_prompt=yes
    else
        color_prompt=
    fi
fi
if [ "$color_prompt" = yes ]; then
    PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
    PS1='${debian_chroot:+($debian_chroot)}\u@\h:\w\$ '
fi
unset color_prompt force_color_prompt
case "$TERM" in
    xterm*|rxvt*)
        PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u@\h: \w\a\]$PS1"
        ;;
esac

# ==============================================================================
# Colors
# ==============================================================================
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# ==============================================================================
# PATH
# ==============================================================================
export PATH="$HOME/.rd/bin:$PATH"               # Rancher Desktop
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/bin:$PATH"
export PATH="$HOME/.local/share/appimages:$PATH"
export PATH="$PATH:/home/mike/.lmstudio/bin"

# ==============================================================================
# Aliases — Files
# ==============================================================================
alias ll='lsd -alFh --group-directories-first'
alias la='lsd -Ah --group-directories-first'
alias l='lsd -CFh --group-directories-first'

# ==============================================================================
# Aliases — Kubernetes
# ==============================================================================
alias k='kubectl'
alias kgp='kubectl get pods'
alias kgpa='kubectl get pods -A'
alias kc='kubectx'
alias kn='kubens'

# ==============================================================================
# Aliases — Chezmoi
# ==============================================================================
alias cz='chezmoi'
alias czcd='chezmoi cd'
alias cze='chezmoi edit'
alias cza='chezmoi apply'
alias czs='chezmoi status'
alias czd='chezmoi diff'
alias czr='chezmoi re-add'

# ==============================================================================
# Aliases — Navigation
# ==============================================================================
alias dot='cd ~/dotfiles'
alias lab='cd ~/repos/lab'
alias repos='cd ~/repos'
alias shop='cd ~/repos/shopify'
alias hl='cd ~/repos/homelab-cluster'

# ==============================================================================
# Aliases — Git
# ==============================================================================
alias ga='git add .'
alias gc='git commit -m'
alias gp='git push'

# ==============================================================================
# Aliases — AI
# ==============================================================================
alias ai='ollama run nous-hermes2'

# ==============================================================================
# Aliases — Phone & Tablet
# ==============================================================================
alias phone='scrcpy -s 2B011FDH3004TJ --turn-screen-off > /dev/null 2>&1 &'
alias tablet='scrcpy -s R52W90F8L8T --turn-screen-off > /dev/null 2>&1 &'

# ==============================================================================
# Kubectl Completion
# ==============================================================================
if command -v kubectl &> /dev/null; then
    source <(kubectl completion bash)
    complete -o default -F __start_kubectl k
fi

# ==============================================================================
# Sway Function
# ==============================================================================
sway() {
{{- if eq .chezmoi.hostname "fedora-desktop" }}
    export LIBVA_DRIVER_NAME=nvidia
    export __GLX_VENDOR_LIBRARY_NAME=nvidia
    export WLR_NO_HARDWARE_CURSORS=1
    export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json
    exec dbus-run-session /usr/bin/sway --unsupported-gpu "$@"
{{- else }}
    exec dbus-run-session /usr/bin/sway "$@"
{{- end }}
}


# ==============================================================================
# Bash Completions
# ==============================================================================
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

if ! shopt -oq posix; then
    if [ -f /usr/share/bash-completion/bash_completion ]; then
        . /usr/share/bash-completion/bash_completion
    elif [ -f /etc/bash_completion ]; then
        . /etc/bash_completion
    fi
fi

# ==============================================================================

# ==============================================================================
# Environment Variables
# ==============================================================================
export EDITOR=vim
export VISUAL=vim
export OLLAMA_HOST=http://ollama.taildb5a91.ts.net:11434
export RECORDINGS_DIR="$HOME/Files/MeetingNotes"

# ==============================================================================
# Local .env
# ==============================================================================
if [ -f ~/.env ]; then
    export $(cat ~/.env | xargs)
fi

# ==============================================================================
# Linuxbrew
# ==============================================================================
if [ -f /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
fi

# ==============================================================================
# DevPod — Custom Starship Config
# ==============================================================================
if [ "$DEVPOD" = "true" ]; then
    export STARSHIP_CONFIG=~/.config/starship-devpod.toml
fi

# ==============================================================================
# Direnv
# ==============================================================================
if command -v direnv &> /dev/null; then
    eval "$(direnv hook bash)"
fi

# ==============================================================================
# Functions
# ==============================================================================
ytnotes() {
    info=$(yt-dlp --print "%(channel)s|||%(title)s" "$1" 2>/dev/null)
    channel=$(echo "$info" | cut -d'|' -f1 | sed 's/[^a-zA-Z0-9 ]//g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1' | tr -d ' ')
    title=$(echo "$info" | cut -d'|' -f4 | sed 's/[^a-zA-Z0-9 ]//g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1' | tr -d ' ')
    echo "Saving to: $(date +%Y%m%d)-${channel}-${title}.md"
    fabric -y "$1" -p extract_wisdom -s | tee ~/Files/"Obsidian Vault"/Fabric/"$(date +%Y%m%d)-${channel}-${title}.md"
}

hushnote() {
    sudo pkill ollama 2>/dev/null
    sleep 1
    local hushnote_dir
    hushnote_dir="$(dirname "$(chezmoi source-path ~/.bashrc 2>/dev/null || echo "$HOME/dotfiles")")"
    if [ "$1" = "speaker" ]; then
        "$hushnote_dir/hushnote-speaker" "$2"
    else
        "$HOME/hushnote/hushnote" "$@"
    fi
    sleep 10
    "$hushnote_dir/hushnote-to-obsidian"
}

# ==============================================================================
# Mise
# ==============================================================================
eval "$(mise activate bash)"

# ==============================================================================
# Starship Prompt
# ==============================================================================
eval "$(starship init bash)"
